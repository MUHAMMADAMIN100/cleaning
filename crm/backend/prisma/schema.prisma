// ============================================================
//  Archidea Sistem — схема базы данных (PostgreSQL)
// ============================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── ENUMS ─────────────────────────

/// Роли доступа. Клинеры в CRM не заходят — это не User.
enum Role {
  DIRECTOR // Руководитель — полный доступ
  MANAGER // Менеджер — только свои данные и своя команда
}

/// Источник обращения клиента
enum LeadSource {
  SITE // сайт (автоматическая заявка)
  INSTAGRAM
  CALL // звонок
  RECOMMENDATION
}

/// Этапы воронки продаж (5.2)
enum FunnelStage {
  NEW // 1. Новая заявка
  PROCESSING // 2. Обработка
  INSPECTION // 3. Осмотр объекта
  OFFER // 4. Коммерческое предложение
  CONFIRMED // 5. Подтверждён
  IN_PROGRESS // 6. В работе
  DONE // 7. Выполнено
  PAID // 8. Оплачено / Закрыто
  REJECTED // 9. Отказ
}

/// Тип уборки (совпадает с калькулятором лендинга)
enum CleaningType {
  MAINTENANCE // Поддерживающая (архив — услуга закрыта, значение хранится для старых заказов)
  GENERAL // Генеральная
  POST_RENOVATION // После ремонта
  FURNITURE // Мойка мягкой мебели (цена за посадочное место)
}

/// Степень загрязнения — определяет цену за м²
enum DirtLevel {
  LIGHT // лёгкая
  MEDIUM // средняя
  HEAVY // тяжёлая
}

/// Как клинер попадёт на объект
enum AccessMethod {
  KEYS // передать ключи
  ONSITE // буду на месте
}

/// Теги клиента
enum ClientTag {
  VIP
  REGULAR // постоянный клиент
  REFUSED // отказник
  POTENTIAL // потенциальный
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum NotificationType {
  NEW_LEAD // новая заявка с сайта (менеджеру)
  NEW_TASK // новая задача от руководителя (менеджеру)
  ORDER_STATUS_CHANGED // смена статуса крупного заказа (руководителю)
  REPORT_SENT // менеджер отправил платёжную ведомость (руководителю)
}

/// Статус платёжной ведомости (отчёта по объекту)
enum ReportStatus {
  DRAFT // черновик
  SENT // отправлен основателю
  ACCEPTED // принят основателем (смены/штрафы разнесены в выплаты)
}

enum ScheduleType {
  INSPECTION // осмотр объекта
  CLEANING_VISIT // выезд команды на уборку
  MEETING // встреча
}

// ───────────────────────── MODELS ─────────────────────────

/// Пользователь системы (Руководитель или Менеджер)
model User {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(MANAGER)
  phone        String?
  position     String? // должность («Операционный управляющий», «Логист»…)
  duties       String? // должностные обязанности (список, по строке на пункт)
  mainTask     String? // основная задача сотрудника
  acceptsLeads Boolean  @default(true) // участвует в авто-распределении заявок с сайта
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // связи
  clients       Client[]        @relation("ManagerClients")
  orders        Order[]         @relation("ManagerOrders")
  cleaners      Cleaner[] // клинеры в команде менеджера
  tasksAssigned Task[]          @relation("TaskAssignee")
  tasksCreated  Task[]          @relation("TaskCreator")
  schedule      ScheduleEvent[]
  notifications Notification[]
  reports       Report[]        @relation("ReportManager")
}

/// Клинер — член бригады. НЕ имеет доступа в CRM.
model Cleaner {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?
  rate      Int      @default(230) // ставка, сомони за смену (бригадир — 330)
  duties    String? // обязанности (для бригадиров)
  isActive  Boolean  @default(true)
  manager   User?    @relation(fields: [managerId], references: [id], onDelete: SetNull)
  managerId String?
  brigade   Brigade? @relation("BrigadeMembers", fields: [brigadeId], references: [id], onDelete: SetNull)
  brigadeId String?
  leaderOf   Brigade?       @relation("BrigadeLeader")
  orders     Order[]        @relation("OrderCleaners")
  shifts     Shift[]
  fines      Fine[]
  reportRows ReportWorker[]
  createdAt  DateTime       @default(now())

  @@index([brigadeId])
}

/// Бригада клинеров (у бригады есть бригадир с повышенной ставкой)
model Brigade {
  id        String    @id @default(cuid())
  name      String    @unique
  leader    Cleaner?  @relation("BrigadeLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  leaderId  String?   @unique
  cleaners  Cleaner[] @relation("BrigadeMembers")
  createdAt DateTime  @default(now())
}

/// Смена клинера (учёт по датам → расчёт выплат)
model Shift {
  id        String   @id @default(cuid())
  date      DateTime // день смены (00:00 UTC)
  cleaner   Cleaner  @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  cleanerId String
  rate      Int // ставка на момент смены (снапшот — не меняется задним числом)
  note      String? // объект/комментарий
  createdAt DateTime @default(now())

  @@unique([cleanerId, date])
  @@index([date])
}

/// Штраф клинеру (сумма + причина, вычитается из выплат)
model Fine {
  id          String   @id @default(cuid())
  cleaner     Cleaner  @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  cleanerId   String
  amount      Int // сомони
  reason      String
  date        DateTime @default(now())
  createdById String? // кто назначил (User.id)
  createdAt   DateTime @default(now())

  @@index([cleanerId, date])
  @@index([date])
}

/// Клиент — ядро базы. Фиксируется КАЖДОЕ обращение.
model Client {
  id            String      @id @default(cuid())
  fullName      String
  phone         String      @unique // защита от дублей по телефону
  email         String?
  source        LeadSource  @default(SITE)
  tags          ClientTag[] @default([])
  notes         String? // комментарии и заметки менеджера
  lastContactAt DateTime    @default(now())
  manager       User?       @relation("ManagerClients", fields: [managerId], references: [id], onDelete: SetNull)
  managerId     String?
  orders        Order[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([managerId])
  // @@index([phone]) убран: @unique на phone уже создаёт индекс
}

/// Заказ / обращение — движется по воронке. История заказов клиента.
model Order {
  id        String      @id @default(cuid())
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  manager   User?       @relation("ManagerOrders", fields: [managerId], references: [id], onDelete: SetNull)
  managerId String?
  stage     FunnelStage @default(NEW)
  source    LeadSource  @default(SITE)

  // параметры уборки (из калькулятора / анкеты)
  cleaningType   CleaningType @default(GENERAL)
  dirtLevel      DirtLevel? // степень загрязнения (для уборки по м²)
  area           Int          @default(0)
  seats          Int? // посадочные места (для мойки мягкой мебели)
  address        String?
  estimatedPrice Int          @default(0) // расчёт с сайта
  finalPrice     Int? // итог после осмотра/КП

  // данные анкеты с сайта
  preferredDate DateTime?
  preferredTime String?
  hasUtilities  Boolean?
  accessMethod  AccessMethod?
  comment       String?
  extras        Json? // выбранные доп. услуги

  // этапы воронки
  inspectionDate  DateTime? // 3. осмотр
  scheduledDate   DateTime? // 5. подтверждённая дата уборки
  rejectionReason String? // 9. причина отказа
  isLarge         Boolean   @default(false) // крупный заказ (для уведомления руководителю)

  cleaners  Cleaner[] @relation("OrderCleaners") // назначенная команда
  reports   Report[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([managerId])
  @@index([stage])
  @@index([clientId])
  @@index([stage, closedAt]) // выручка по периодам и подсчёт закрытых
}

/// Задача от руководителя менеджеру
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  deadline    DateTime?
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  assigneeId  String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assigneeId])
}

/// Событие расписания менеджера (осмотры, выезды, встречи)
model ScheduleEvent {
  id        String       @id @default(cuid())
  title     String
  type      ScheduleType @default(MEETING)
  date      DateTime
  note      String?
  orderId   String?
  manager   User         @relation(fields: [managerId], references: [id], onDelete: Cascade)
  managerId String
  createdAt DateTime     @default(now())

  @@index([managerId, date])
}

/// Уведомление внутри CRM (колокольчик)
model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  orderId   String?
  taskId    String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

/// Платёжная ведомость по объекту (отчёт менеджера основателю)
model Report {
  id     String       @id @default(cuid())
  status ReportStatus @default(DRAFT)

  // объект (снапшоты — отчёт не меняется при правках заказа)
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId       String?
  clientName    String
  clientPhone   String?
  address       String?
  workDate      DateTime? // дата начала работ
  workEndDate   DateTime? // дата завершения (если многодневный объект)
  unitsLabel    String? // «180 м² по 25 с» — площадь/места и цена за единицу
  extraServices String? // доп. услуга и стоимость на единицу (текстом, как на бланке)
  discount      Int       @default(0) // предоставленная скидка
  totalPrice    Int       @default(0) // итоговая стоимость (выручка по объекту)
  arrivedBy     String? // прибыл(а)
  brigadierName String? // ответственный бригадир
  managerName   String? // ответственный менеджер (снапшот)

  manager      User      @relation("ReportManager", fields: [managerId], references: [id], onDelete: Cascade)
  managerId    String
  sentAt       DateTime?
  acceptedAt   DateTime?
  acceptedById String?

  workers  ReportWorker[]
  expenses ReportExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId, status])
  @@index([status])
}

/// Строка таблицы работников ведомости
model ReportWorker {
  id        String   @id @default(cuid())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  cleaner   Cleaner? @relation(fields: [cleanerId], references: [id], onDelete: SetNull)
  cleanerId String?
  fullName  String // снапшот ФИО
  role      String  @default("Клинер") // «Бригадир» / «Клинер»
  days      Int     @default(1) // дней/смен
  rate      Int // ставка за день (снапшот)
  fine      Int     @default(0) // штраф
  extra     Int     @default(0) // доп. услуги (сумма)
  // сумма к выплате = days × rate − fine + extra (вычисляется)

  @@index([reportId])
}

/// Строка «Доп. расходы» ведомости
model ReportExpense {
  id        String  @id @default(cuid())
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String
  title     String // наименование расхода
  initiator String? // инициатор
  amount    Int // сумма
  comment   String? // комментарий

  @@index([reportId])
}

/// Тариф — цены по типу уборки и степени загрязнения (управление руководителем)
model Tariff {
  id          String       @id @default(cuid())
  key         CleaningType @unique
  title       String
  pricePerSqm Int // legacy: держим = priceMedium (старые клиенты API)
  priceLight  Int          @default(0) // лёгкая степень загрязнения
  priceMedium Int          @default(0) // средняя
  priceHeavy  Int          @default(0) // тяжёлая
  hasLevels   Boolean      @default(true) // false — одна цена (мягкая мебель: за место)
  unit        String       @default("м²") // единица: «м²» или «место»
  updatedAt   DateTime     @updatedAt
}

/// Доп. услуга с фиксированной ценой (управление руководителем)
model ExtraService {
  id        String   @id @default(cuid())
  key       String   @unique // windows / fridge / oven / ironing
  title     String
  price     Int
  hasQty    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
