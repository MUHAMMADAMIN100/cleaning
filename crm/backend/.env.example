# PostgreSQL (Railway даст этот URL автоматически)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# JWT — обязательно поменяйте в продакшене на длинный случайный ключ
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

PORT=4000
NODE_ENV=production

# URL фронтенда CRM (Vercel) и лендинга — для CORS
FRONTEND_URL="https://your-crm.vercel.app"
LANDING_URL="https://your-landing.vercel.app"

# Ключ, которым лендинг авторизуется при отправке заявки в CRM
LEADS_INTAKE_API_KEY="change_me_to_a_random_key"
