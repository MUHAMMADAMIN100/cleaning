# ============================================================
#  Переменные окружения «Архыдея клининг»
#  Скопируйте этот файл в .env и заполните значения.
# ============================================================

# Telegram-бот компании (основной канал получения заявок).
# 1. Создайте бота через @BotFather -> получите токен.
# 2. Узнайте chat_id (для чата/группы) через @getmyid_bot или @userinfobot.
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# CRM-эндпоинт (необязательно, задел на будущее).
# Когда появится CRM — укажите URL, заявки начнут уходить и туда.
VITE_CRM_ENDPOINT=
